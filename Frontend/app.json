{
  "expo": {
    "name": "Monk HRMS",
    "slug": "monk-hrms",
    "version": "2.0.0",

    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "scheme": "monkhrms",

    "newArchEnabled": true,

    "assetBundlePatterns": [
      "**/*"
    ],

    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0B1220"
    },

    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.monkgroup.hrms",
      "buildNumber": "2.0.0"
    },

    "android": {
      "package": "com.monk.hrms",
      "versionCode": 200,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0B1220"
      },
      "softwareKeyboardLayoutMode": "resize",
      "usesCleartextTraffic": false
    },

    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },

    "plugins": [
      "expo-router",
      "expo-splash-screen",
      "expo-system-ui"
    ],

    "updates": {
      "enabled": true,
      "fallbackToCacheTimeout": 0
    },

    "runtimeVersion": {
      "policy": "appVersion"
    },

    "experiments": {
      "typedRoutes": true
    }
  }
}